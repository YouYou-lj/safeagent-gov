{
  "name": "safeagent-gov-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run"
  },
  "dependencies": {
    "@element-plus/icons-vue": "2.3.2",
    "@tauri-apps/api": "2.11.1",
    "axios": "1.18.1",
    "element-plus": "2.14.3",
    "pinia": "4.0.2",
    "vue": "3.5.40",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@vitejs/plugin-vue": "6.0.8",
    "@vue/test-utils": "2.4.11",
    "eslint": "10.7.0",
    "eslint-plugin-vue": "10.9.2",
    "jsdom": "29.1.1",
    "sass": "1.101.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "unplugin-vue-components": "32.1.0",
    "vite": "7.3.6",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  }
}
