# Python/uv environment isolation. Keep uv.lock and .python-version tracked.
/.venv/
/.uv-cache/
/.uv-python/
__pycache__/
*.py[cod]
*.pyd
*.so
*.egg-info/
/build/
/dist/
node_modules/
/frontend-vue/dist/
/frontend-vue/coverage/
/frontend-vue/*.tsbuildinfo
/desktop/node_modules/
/desktop/.build/
/desktop/src-tauri/gen/
/desktop/src-tauri/target/
/desktop/src-tauri/binaries/*
!/desktop/src-tauri/binaries/README.md
/.planning/

# Test, type, lint and coverage caches/reports.
/.pytest_cache/
/.mypy_cache/
/.ruff_cache/
/.coverage
/.coverage.*
/coverage.xml
/htmlcov/
/.hypothesis/
/.tox/
/.nox/

# Local environment, credentials and IDE metadata.
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
*.mobileprovision
*.provisionprofile
*.keystore
*.jks
*.log
*.tmp
*.swp
.DS_Store
.idea/
.vscode/

# Runtime databases, local secrets and generated outputs.
/backend/data/
/agent_demo/data/
/research_technology/evaluation/results/
/research_technology/evidence/reports/
/research_technology/evidence/technical/*.json
!/research_technology/evidence/technical/README.md
!/research_technology/evidence/technical/sbom.cdx.json
!/research_technology/evidence/technical/technical_manifest.json
/release/*
!/release/README.md
!/release/mac/
!/release/windows/
!/release/linux/
/release/mac/*
/release/windows/*
/release/linux/*
!/release/mac/README.md
!/release/windows/README.md
!/release/linux/README.md

# Test/benchmark datasets and generated benchmark evidence are local-only.
/research_technology/datasets/
/research_technology/benchmarks/datasets/
/research_technology/benchmarks/results/
/research_technology/benchmarks/failures/

# Local archives and uploaded scan targets.
*.zip
*.tar
*.tar.gz
*.tgz
