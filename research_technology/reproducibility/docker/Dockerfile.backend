FROM python:3.11-slim@sha256:db3ff2e1800a8581e2c48a27c3995339d47bdf046da21c7627accd3d51053a93 AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    SAFEAGENT_DB_PATH=/app/backend/data/safeagent.db

RUN groupadd --gid 10001 safeagent \
    && useradd --uid 10001 --gid 10001 --create-home --shell /usr/sbin/nologin safeagent

WORKDIR /app
COPY requirements.lock .
RUN pip install --no-cache-dir --requirement requirements.lock \
    && python -m pip check

FROM base AS runtime

COPY --chown=safeagent:safeagent . .
RUN mkdir -p /app/backend/data /app/agent_demo/data/output /app/research_technology/evaluation/results \
    && chown -R safeagent:safeagent /app/backend/data /app/agent_demo/data/output /app/research_technology/evaluation/results

USER 10001:10001
EXPOSE 8000

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]

FROM base AS verification

COPY requirements-dev.lock .
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --requirement requirements-dev.lock \
    && python -m pip check
COPY --chown=safeagent:safeagent . .
RUN mkdir -p /app/backend/data /app/agent_demo/data/output /app/research_technology/evaluation/results \
    && chown -R safeagent:safeagent /app/backend/data /app/agent_demo/data/output /app/research_technology/evaluation/results

USER 10001:10001
EXPOSE 8000

CMD ["python", "research_technology/reproducibility/scripts/container_verify.py", "--profile", "smoke"]
