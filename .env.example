SAFEAGENT_API_URL=http://localhost:8000
SAFEAGENT_DB_PATH=backend/data/safeagent.db
SAFEAGENT_MAX_UPLOAD_MB=10
SAFEAGENT_API_RATE_LIMIT=120
SAFEAGENT_API_RATE_WINDOW_SECONDS=60
SAFEAGENT_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,http://localhost:5173,http://127.0.0.1:5173
SAFEAGENT_TRUSTED_HOSTS=localhost,127.0.0.1,backend

# Production deployments should inject independent random values of at least
# 32 bytes. Empty values use mode-0600 local key files in backend/data.
SAFEAGENT_AUTH_SIGNING_SECRET=
SAFEAGENT_AUDIT_SIGNING_SECRET=
SAFEAGENT_CAPABILITY_SECRET=

# Optional planning-only external Agent integration. Plain HTTP is accepted
# only on loopback; non-loopback endpoints must use HTTPS.
SAFEAGENT_EXTERNAL_AGENT_ENDPOINT=
SAFEAGENT_EXTERNAL_AGENT_TOKEN=
SAFEAGENT_EXTERNAL_AGENT_NAME=safeagent-reference-tool-agent
SAFEAGENT_EXTERNAL_AGENT_TIMEOUT_SECONDS=15
